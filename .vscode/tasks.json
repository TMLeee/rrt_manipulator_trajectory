{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "shell",
			"label": "build (main.cpp)",
			"command": "/usr/bin/g++",
			"args": [
				"-std=c++17",
				"-fdiagnostics-color=always",
				"-g",
				"-O0",
				"${workspaceFolder}/main.cpp",
				"${workspaceFolder}/MujocoEnv.cpp",
				"${workspaceFolder}/MujocoRobotModel.cpp",
				"${workspaceFolder}/RbdlRobotModel.cpp",
				"${workspaceFolder}/Controller.cpp",
				"${workspaceFolder}/HierarchicalSolver.cpp",
				"${workspaceFolder}/FrameTask.cpp",
				"${workspaceFolder}/JointSpaceTask.cpp",
				"-o",
				"${workspaceFolder}/main",
				"-I/opt/mujoco/mujoco/include",
				"-I/usr/local/include",
				"-I/usr/include/eigen3",
				"-L/opt/mujoco/mujoco/lib",
				"-L/usr/local/lib",
				"-Wl,-rpath,/opt/mujoco/mujoco/lib",
				"-Wl,-rpath,/usr/local/lib",
				"-lmujoco",
				"-lrbdl",
				"-lrbdl_urdfreader",
				"-lglfw",
				"-lGLEW",
				"-lGL",
				"-ldl",
				"-lpthread"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"detail": "프로젝트 전체 빌드 (main.cpp -> ./main), MuJoCo + RBDL + GLFW 링크"
		},
		{
			"type": "shell",
			"label": "build (test_clik)",
			"command": "/usr/bin/g++",
			"args": [
				"-std=c++17",
				"-fdiagnostics-color=always",
				"-g",
				"-O2",
				"${workspaceFolder}/test_clik.cpp",
				"${workspaceFolder}/MujocoRobotModel.cpp",
				"${workspaceFolder}/Controller.cpp",
				"${workspaceFolder}/HierarchicalSolver.cpp",
				"${workspaceFolder}/FrameTask.cpp",
				"${workspaceFolder}/JointSpaceTask.cpp",
				"-o",
				"${workspaceFolder}/test_clik",
				"-I/opt/mujoco/mujoco/include",
				"-I/usr/local/include",
				"-I/usr/include/eigen3",
				"-L/opt/mujoco/mujoco/lib",
				"-L/usr/local/lib",
				"-Wl,-rpath,/opt/mujoco/mujoco/lib",
				"-Wl,-rpath,/usr/local/lib",
				"-lmujoco",
				"-lrbdl",
				"-lrbdl_urdfreader",
				"-ldl",
				"-lpthread"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": "build",
			"detail": "headless CLIK 수렴 테스트 빌드 (GLFW 불필요)"
		}
	]
}
